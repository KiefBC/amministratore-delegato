@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits PanelComponent

<root class="@RootClass">
	<div class="chat-window">
		<div class="chat-title">Placeholder Chat Title</div>

		@if ( !IsIdleCollapsed && HasBusinessCard )
		{
			<div class="business-card">
				<div class="business-card-topline">
					<span class="business-card-kicker">Business Card</span>
					<span class="business-card-close" onclick="@HideBusinessCard">x</span>
				</div>
				<div class="business-card-name">@BusinessCardName()</div>
				<div class="business-card-row">
					<span>Net Worth</span>
					<strong>$@BusinessCardWorth().ToString( "N0" )</strong>
				</div>
				<div class="business-card-row">
					<span>Affiliation</span>
					<strong>@BusinessCardAffiliation()</strong>
				</div>
			</div>
		}

		@if ( !IsIdleCollapsed )
		{
			<div class="chat-messages">
				@foreach ( var message in VisibleMessages() )
				{
					<div class="chat-message">
						@if ( CanOpenBusinessCard( message ) )
						{
							<span class="chat-sender interactive" onclick="@(() => ShowBusinessCard( message ))">@message.SenderName</span>
						}
						else
						{
							<span class="chat-sender">@message.SenderName</span>
						}
						<span class="chat-separator">:</span>
						<span class="chat-text">@message.Message</span>
					</div>
				}
			</div>

			@if ( _isOpen )
			{
				<div class="chat-input-row">
					<span class="chat-prompt">&gt;</span>
					<TextEntry @ref="_input" class="chat-input" Value:bind=@_draft onsubmit="@SubmitMessage" placeholder="Type global message..." />
				</div>
			}
			else
			{
				<div class="chat-input-row inactive">
					<span class="chat-prompt">&gt;</span>
					<span class="chat-input-placeholder">Press Enter to chat...</span>
				</div>
			}
		}
	</div>
</root>

@code {
	private const int OpenMessageCount = 10;
	private const int ClosedMessageCount = OpenMessageCount;
	private const float IdleCollapseDelay = 300f;

	private TextEntry _input = null;
	private ChatSystem _chat;
	private UIStateManager _uiState;
	private GameObject _player;
	private Sandbox.UI.Panel _messagesPanel;
	private ChatMessageEntry _businessCardMessage;
	private GameObject _businessCardPlayer;
	private string _draft = "";
	private int _historyScrollOffset;
	private bool _isOpen;
	private bool _pendingFocus;
	private bool _suppressOpenUntilChatReleased;

	private string RootClass => _isOpen ? "open" : (IsIdleCollapsed ? "closed collapsed" : "closed");
	private IReadOnlyList<ChatMessageEntry> Messages => _chat?.Messages ?? System.Array.Empty<ChatMessageEntry>();
	private bool HasBusinessCard => _isOpen && _businessCardMessage is not null && _businessCardPlayer.IsValid();
	private bool IsIdleCollapsed => !_isOpen && (_chat?.SecondsSinceLastMessage ?? 0f) >= IdleCollapseDelay;

	protected override void OnUpdate()
	{
		_chat = ChatSystem.Current;
		FindLocalPlayer();

		if ( _suppressOpenUntilChatReleased && !Input.Down( "Chat" ) )
		{
			_suppressOpenUntilChatReleased = false;
		}

		if ( !_isOpen && !_suppressOpenUntilChatReleased && Input.Pressed( "Chat" ) )
		{
			Open();
		}

		if ( !_isOpen ) return;
		if ( _businessCardMessage is not null && !_businessCardPlayer.IsValid() ) HideBusinessCard();

		if ( _pendingFocus && _input is not null )
		{
			_input.Focus();
			_pendingFocus = false;
		}

		if ( Input.EscapePressed )
		{
			Input.EscapePressed = false;
			Close( clearDraft: true );
		}

		PollHistoryScroll();
	}

	private void Open()
	{
		if ( _isOpen ) return;

		_isOpen = true;
		_historyScrollOffset = 0;
		_pendingFocus = true;
		_messagesPanel = null;
		_uiState?.RequestUIFocus( this );
	}

	private void Close( bool clearDraft )
	{
		if ( !_isOpen ) return;

		_isOpen = false;
		_pendingFocus = false;
		_suppressOpenUntilChatReleased = true;
		_historyScrollOffset = 0;
		_messagesPanel = null;
		HideBusinessCard();
		_uiState?.ReleaseUIFocus( this );
		_input?.Blur();

		if ( clearDraft ) _draft = "";
	}

	private void SubmitMessage()
	{
		var text = _input?.Text ?? _draft ?? "";
		_draft = "";
		if ( _input is not null ) _input.Text = "";

		Close( clearDraft: true );

		if ( string.IsNullOrWhiteSpace( text ) ) return;
		if ( !_player.IsValid() ) return;

		GameNetworkRpc.RequestSendChatMessage( _player, text );
	}

	private void FindLocalPlayer()
	{
		if ( Sandbox.LocalPlayer.Owns( _player ) ) return;

		_player = Sandbox.LocalPlayer.GameObject( Scene );
		_uiState = _player?.Components.Get<UIStateManager>();
	}

	private IEnumerable<ChatMessageEntry> VisibleMessages()
	{
		var count = _isOpen ? OpenMessageCount : ClosedMessageCount;
		var offset = _isOpen ? int.Clamp( _historyScrollOffset, 0, MaxHistoryScrollOffset() ) : 0;
		var start = int.Max( 0, Messages.Count - count - offset );
		return Messages.Skip( start ).Take( count );
	}

	private void PollHistoryScroll()
	{
		if ( Panel is null ) return;

		_messagesPanel = FindByClass( Panel, "chat-messages" );
		if ( _messagesPanel is null || !_messagesPanel.IsInside( Mouse.Position ) ) return;

		var wheel = Input.MouseWheel.y;
		if ( wheel == 0f ) return;

		var direction = wheel > 0f ? 1 : -1;
		_historyScrollOffset = int.Clamp( _historyScrollOffset + direction, 0, MaxHistoryScrollOffset() );
	}

	private int MaxHistoryScrollOffset()
	{
		return int.Max( 0, Messages.Count - OpenMessageCount );
	}

	private static Sandbox.UI.Panel FindByClass( Sandbox.UI.Panel root, string className )
	{
		if ( root is null ) return null;
		if ( root.HasClass( className ) ) return root;

		foreach ( var child in root.Children )
		{
			var found = FindByClass( child, className );
			if ( found is not null ) return found;
		}

		return null;
	}

	private bool CanOpenBusinessCard( ChatMessageEntry message )
	{
		return _isOpen && message?.Sender.IsValid() == true;
	}

	private void ShowBusinessCard( ChatMessageEntry message )
	{
		if ( !CanOpenBusinessCard( message ) ) return;

		_businessCardMessage = message;
		_businessCardPlayer = message.Sender;
	}

	private void HideBusinessCard()
	{
		_businessCardMessage = null;
		_businessCardPlayer = null;
	}

	private string BusinessCardName()
	{
		if ( !string.IsNullOrWhiteSpace( _businessCardMessage?.SenderName ) ) return _businessCardMessage.SenderName;

		var owner = OwnerFor( _businessCardPlayer );
		if ( owner is not null && !string.IsNullOrWhiteSpace( owner.DisplayName ) ) return owner.DisplayName;

		return _businessCardPlayer.IsValid() && !string.IsNullOrWhiteSpace( _businessCardPlayer.Name )
			? TrimSpawnedPlayerPrefix( _businessCardPlayer.Name )
			: "Player";
	}

	private long BusinessCardWorth()
	{
		var backpack = BusinessCardBackpack();
		if ( !backpack.IsValid() ) return 0;

		long total = backpack.Wallet;
		foreach ( var item in backpack.Items.Values )
		{
			if ( !item.IsValid ) continue;

			var definition = backpack.GetDefinition( item );
			if ( definition is null ) continue;

			total += (long)definition.Value * item.StackCount;
		}

		return total;
	}

	private string BusinessCardAffiliation()
	{
		var profile = BusinessCardProfile();
		return profile.IsValid()
			? profile.AffiliationDisplayName
			: PlayerProfileComponent.DisplayNameForAffiliation( PlayerProfileComponent.IndependentAffiliationId );
	}

	private Backpack BusinessCardBackpack()
	{
		if ( !_businessCardPlayer.IsValid() ) return null;

		var backpack = _businessCardPlayer.Components.GetInDescendantsOrSelf<Backpack>();
		if ( backpack.IsValid() ) return backpack;

		var root = _businessCardPlayer.Root;
		return root.IsValid() && root != _businessCardPlayer
			? root.Components.GetInDescendantsOrSelf<Backpack>()
			: null;
	}

	private PlayerProfileComponent BusinessCardProfile()
	{
		if ( !_businessCardPlayer.IsValid() ) return null;

		var profile = _businessCardPlayer.Components.GetInDescendantsOrSelf<PlayerProfileComponent>();
		if ( profile.IsValid() ) return profile;

		var root = _businessCardPlayer.Root;
		return root.IsValid() && root != _businessCardPlayer
			? root.Components.GetInDescendantsOrSelf<PlayerProfileComponent>()
			: null;
	}

	private static Connection OwnerFor( GameObject player )
	{
		if ( !player.IsValid() ) return null;

		var owner = player.Network.Owner;
		if ( owner is not null ) return owner;

		var root = player.Root;
		return root.IsValid() && root != player ? root.Network.Owner : null;
	}

	private static string TrimSpawnedPlayerPrefix( string name )
	{
		const string spawnedPlayerPrefix = "Player - ";
		if ( name.StartsWith( spawnedPlayerPrefix, System.StringComparison.OrdinalIgnoreCase ) )
		{
			name = name[spawnedPlayerPrefix.Length..];
		}

		return string.IsNullOrWhiteSpace( name ) ? "Player" : name.Trim();
	}

	protected override int BuildHash()
	{
		var hc = new System.HashCode();
		hc.Add( _isOpen );
		hc.Add( _chat?.ChatVersion ?? 0 );
		hc.Add( _suppressOpenUntilChatReleased );
		hc.Add( _historyScrollOffset );
		hc.Add( _businessCardMessage?.Id ?? -1 );
		hc.Add( IsIdleCollapsed );

		if ( HasBusinessCard )
		{
			var backpack = BusinessCardBackpack();
			var profile = BusinessCardProfile();
			hc.Add( backpack?.Wallet ?? 0 );
			hc.Add( backpack?.InventoryVersion ?? 0 );
			hc.Add( profile?.AffiliationId ?? "" );
		}

		foreach ( var message in VisibleMessages() )
		{
			hc.Add( message.Id );
		}

		return hc.ToHashCode();
	}
}
