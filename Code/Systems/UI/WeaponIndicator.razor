@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@namespace Sandbox
@inherits PanelComponent
@implements IEquipmentChangedListener
@implements IHolsterChangedListener

<root>
	@if ( !string.IsNullOrEmpty( _weaponName ) )
	{
		<div class="weapon @(_holstered ? "holstered" : "")">
			<span class="state">@(_holstered ? "Holstered" : "Equipped")</span>
			<span class="name">@_weaponName</span>
		</div>
	}
</root>

@code {
	private string _weaponName;
	private bool _holstered;

	public void OnEquipmentChanged( Inventory inventory, GameObject equipped )
	{
		_weaponName = equipped?.Name;
		// New pickup is drawn by default — Inventory.Equip doesn't holster.
		if ( equipped is not null ) _holstered = false;
	}

	public void OnHolsterChanged( WeaponBehavior weapon, bool holstered )
	{
		_holstered = holstered;
	}

	protected override void OnStart()
	{
		var inventory = Scene.GetAllComponents<Inventory>().FirstOrDefault();
		if ( inventory?.Equipped.IsValid() == true )
		{
			_weaponName = inventory.Equipped.Name;
		}

		var weapon = Scene.GetAllComponents<WeaponBehavior>().FirstOrDefault();
		if ( weapon is not null )
		{
			_holstered = weapon.IsHolstered;
		}
	}

	protected override int BuildHash() => System.HashCode.Combine( _weaponName, _holstered );
}

<style>
	root {
		width: 100%;
		height: 100%;
		position: absolute;
		pointer-events: none;
	}

	.weapon {
		position: absolute;
		right: 32px;
		bottom: 32px;
		flex-direction: column;
		align-items: flex-end;
		gap: 2px;
		padding: 10px 16px;
		background-color: rgba( 0, 0, 0, 0.55 );
		border-radius: 8px;
		font-family: Roboto, sans-serif;
		transition: opacity 0.15s ease-out;
	}

	.weapon.holstered {
		opacity: 0.55;
	}

	.state {
		color: #b8b8b8;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.name {
		color: white;
		font-size: 22px;
		font-weight: bold;
		text-shadow: 0px 0px 4px rgba( 0, 0, 0, 0.9 );
	}
</style>
