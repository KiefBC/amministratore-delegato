@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@namespace Sandbox
@inherits PanelComponent
@implements IEquipmentChangedListener
@implements IHolsterChangedListener
@implements IWeaponStateChangedListener

<root>
	@if ( !string.IsNullOrEmpty( _weaponName ) )
	{
		<div class="weapon @PanelStateClass">
			<span class="state">@StateLabel</span>
			<span class="name">@_weaponName</span>
			@if ( _state == WeaponBehavior.WeaponState.Reloading )
			{
				<div class="reload-bar-bg">
					<div class="reload-bar-fill" style="width: @(_reloadProgress * 100)%;"></div>
				</div>
			}
			else
			{
				<span class="ammo @AmmoClass">@_currentAmmo / @_magazineSize</span>
			}
		</div>
	}
</root>

@code {
	private string _weaponName;
	private bool _holstered;
	private WeaponBehavior _weapon;

	private WeaponBehavior.WeaponState _state = WeaponBehavior.WeaponState.Idle;
	private int _currentAmmo;
	private int _magazineSize = 1;
	private float _reloadProgress;

	private string PanelStateClass
	{
		get
		{
			if ( _holstered ) return "holstered";
			if ( _state == WeaponBehavior.WeaponState.Reloading ) return "reloading";
			if ( _state == WeaponBehavior.WeaponState.Empty ) return "empty";
			return "";
		}
	}

	private string StateLabel
	{
		get
		{
			if ( _holstered ) return "Holstered";
			return _state switch
			{
				WeaponBehavior.WeaponState.Reloading => "Reloading",
				WeaponBehavior.WeaponState.Empty => "Empty",
				_ => "Equipped",
			};
		}
	}

	private string AmmoClass => _state == WeaponBehavior.WeaponState.Empty ? "ammo-empty" : "";

	public void OnEquipmentChanged( Inventory inventory, GameObject equipped )
	{
		_weaponName = equipped?.Name;
		if ( equipped is not null ) _holstered = false;
	}

	public void OnHolsterChanged( WeaponBehavior weapon, bool holstered )
	{
		_holstered = holstered;
	}

	public void OnWeaponStateChanged( WeaponBehavior weapon )
	{
		_weapon = weapon;
		_state = weapon.State;
		_currentAmmo = weapon.CurrentAmmo;
		_magazineSize = weapon.MagazineSize;
		_reloadProgress = weapon.ReloadProgress;
	}

	protected override void OnStart()
	{
		var inventory = Scene.GetAllComponents<Inventory>().FirstOrDefault();
		if ( inventory?.Equipped.IsValid() == true )
		{
			_weaponName = inventory.Equipped.Name;
		}

		_weapon = Scene.GetAllComponents<WeaponBehavior>().FirstOrDefault();
		if ( _weapon is not null )
		{
			_holstered = _weapon.IsHolstered;
			_state = _weapon.State;
			_currentAmmo = _weapon.CurrentAmmo;
			_magazineSize = _weapon.MagazineSize;
		}
	}

	protected override void OnUpdate()
	{
		// Reload progress is continuous — sample it each frame so the bar animates
		// smoothly. The state-change broadcast only fires on transitions, not per-tick.
		if ( _state == WeaponBehavior.WeaponState.Reloading && _weapon is not null )
		{
			_reloadProgress = _weapon.ReloadProgress;
		}
	}

	protected override int BuildHash() => System.HashCode.Combine(
		_weaponName, _holstered, _state, _currentAmmo, _magazineSize,
		_state == WeaponBehavior.WeaponState.Reloading ? (int)(_reloadProgress * 100) : 0 );
}
