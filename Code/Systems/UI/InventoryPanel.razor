@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@namespace Sandbox
@inherits PanelComponent
@implements IInventoryChangedListener

<root class="@(IsOpen ? "open" : "")">
	@if ( IsOpen && _backpack.IsValid() )
	{
		<div class="center-wrap">
		<div class="inventory-anchor">
		<div class="inventory">
			<div class="header">
				<span class="title">Inventory</span>
				<div class="sort-buttons">
					<div class="sort-button @(_hoveredSortButton == Backpack.SortMode.New ? "hover" : "")">New</div>
					<div class="sort-button @(_hoveredSortButton == Backpack.SortMode.Worth ? "hover" : "")">Worth</div>
					<div class="sort-button @(_hoveredSortButton == Backpack.SortMode.Weight ? "hover" : "")">Weight</div>
				</div>
			</div>

			<div class="grid">
				@for ( int r = 0; r < _backpack.Rows; r++ )
				{
					<div class="grid-row">
						@for ( int c = 0; c < _backpack.Cols; c++ )
						{
							var row = r;
							var col = c;
							// While dragging, the source cell renders as empty so the user
							// sees the item leave its slot and follow the cursor.
							var isDragSource = _dragging && _dragSource.HasValue
								&& _dragSource.Value.row == row && _dragSource.Value.col == col;
							var item = isDragSource ? null : _backpack.Slots[row, col];
							var selected = !isDragSource
								&& _backpack.Selected is var sel && sel.HasValue
								&& sel.Value.row == row && sel.Value.col == col;
							<div class="cell @(item.IsValid() ? "filled" : "empty") @(selected ? "selected" : "")"
								 style="@CellStyle(item, selected)">
								@if ( item.IsValid() )
								{
									@if ( !string.IsNullOrEmpty( item.Icon ) )
									{
										<div class="icon" style="background-image: url(@item.Icon);"></div>
									}
									else
									{
										<div class="icon-fallback">@FallbackLabel(item)</div>
									}
									@if ( item.StackCount > 1 )
									{
										<div class="stack">@FormatStack(item)</div>
									}
								}
							</div>
						}
					</div>
				}
			</div>

			<div class="footer">
				<span class="hint">Tab / Esc to close · Right-click to use · Drag to move · Drag out to drop</span>
			</div>
		</div>

		@if ( !_dragging && _hoveredSlot.HasValue )
		{
			var hoverItem = _backpack.Slots[_hoveredSlot.Value.row, _hoveredSlot.Value.col];
			if ( hoverItem.IsValid() )
			{
				<div class="tooltip">
					<div class="tooltip-header">
						<span class="tooltip-name">@TooltipName(hoverItem)</span>
						<span class="tooltip-rarity rarity-@hoverItem.Rarity.ToString().ToLowerInvariant()">@hoverItem.Rarity</span>
					</div>
					<div class="tooltip-divider"></div>
					<div class="tooltip-rows">
						@foreach ( var (label, value) in TooltipRows( hoverItem ) )
						{
							@if ( label == "—" )
							{
								<div class="tooltip-divider"></div>
							}
							else
							{
								<div class="tooltip-row">
									<span class="tooltip-label">@label</span>
									<span class="tooltip-value">@value</span>
								</div>
							}
						}
					</div>
				</div>
			}
		}
		</div>
		</div>

		@if ( _dragging && _dragSource.HasValue )
		{
			var ghostItem = _backpack.Slots[_dragSource.Value.row, _dragSource.Value.col];
			if ( ghostItem.IsValid() )
			{
				<div class="drag-ghost"
					 style="left: @(CursorCss.x - 32)px; top: @(CursorCss.y - 32)px; @GhostBackground(ghostItem)">
					@if ( string.IsNullOrEmpty( ghostItem.Icon ) )
					{
						<div class="icon-fallback">@FallbackLabel(ghostItem)</div>
					}
				</div>
			}
		}
	}
</root>

@code {
	private const float DragThresholdPx = 6f;

	private Backpack _backpack;
	private UIStateManager _uiState;
	private GameObject _player;

	private bool _isOpen;
	private (int row, int col)? _dragSource;
	private bool _dragging;
	private Vector2 _mouseDownPos;
	private Vector2 _mousePos;
	private (int row, int col)? _hoveredSlot;
	private Backpack.SortMode? _hoveredSortButton;
	private Sandbox.UI.Panel _gridPanel;
	private Sandbox.UI.Panel _sortButtonsPanel;

	// `Mouse.Position` is raw screen pixels; inline `style="left: Xpx"` is interpreted
	// in CSS pixels (the ScreenPanel runs at ConsistentHeight=1080). Convert via the
	// physical screen height so the ghost lands directly under the cursor at any res.
	// (We tried `Panel.MousePosition` first — at non-1080p its values placed the ghost
	// far off the cursor, so we compute the conversion ourselves.)
	private Vector2 CursorCss
	{
		get
		{
			var sh = Screen.Height;
			if ( sh <= 1 ) return Mouse.Position;
			var scale = 1080f / sh;
			return new Vector2( Mouse.Position.x * scale, Mouse.Position.y * scale );
		}
	}

	public bool IsOpen => _isOpen;

	public void OnInventoryChanged( Backpack backpack )
	{
		// Listener trigger — BuildHash picks up the new state on the next layout.
	}

	protected override void OnStart()
	{
		_player = Scene.GetAllComponents<PlayerController>()
			.FirstOrDefault( p => !p.IsProxy )?.GameObject;
		_backpack = _player?.Components.GetInDescendantsOrSelf<Backpack>();
		_uiState = _player?.Components.Get<UIStateManager>();
	}

	protected override void OnUpdate()
	{
		_mousePos = Mouse.Position;

		if ( Input.Pressed( "Inventory" ) )
		{
			Toggle();
		}
		else if ( _isOpen && Input.EscapePressed )
		{
			Close();
		}

		if ( _isOpen && _dragSource.HasValue && !_dragging )
		{
			if ( (_mousePos - _mouseDownPos).Length > DragThresholdPx )
			{
				_dragging = true;
			}
		}

		PollHoveredSlot();
		PollHoveredSortButton();
		PollMouseInput();
	}

	/// <summary>
	/// Razor mouse handlers (`@onmousedown`, `@onmouseup`, `@onclick`) don't reliably
	/// fire on plain &lt;div&gt; elements in s&amp;box's parser, so all click/drag
	/// behavior is driven by polling `Input.Pressed/Released` here against the
	/// already-polled `_hoveredSlot` / `_hoveredSortButton`.
	/// </summary>
	private void PollMouseInput()
	{
		if ( !_isOpen || !_backpack.IsValid() || Panel is null ) return;

		if ( Input.Pressed( "Attack1" ) )
		{
			if ( _hoveredSortButton.HasValue )
			{
				_backpack.Sort( _hoveredSortButton.Value );
			}
			else if ( _hoveredSlot.HasValue )
			{
				var (row, col) = _hoveredSlot.Value;
				if ( _backpack.Slots[row, col].IsValid() )
				{
					_dragSource = (row, col);
					_mouseDownPos = _mousePos;
					_dragging = false;
					// Clear any prior selection so a stale green glow doesn't linger
					// on the source cell during the drag.
					_backpack.ClearSelection();
				}
			}
		}

		if ( Input.Released( "Attack1" ) && _dragSource.HasValue )
		{
			var src = _dragSource.Value;
			var wasDragging = _dragging;
			_dragSource = null;
			_dragging = false;

			if ( wasDragging )
			{
				if ( _hoveredSlot.HasValue && _hoveredSlot.Value != src )
				{
					_backpack.MoveSlot( src.row, src.col, _hoveredSlot.Value.row, _hoveredSlot.Value.col );
				}
				else if ( !_hoveredSlot.HasValue )
				{
					_backpack.DropToWorld( src.row, src.col );
				}
			}
			else
			{
				// Click without drag → toggle selection on the source cell.
				if ( _backpack.Selected is var sel && sel.HasValue && sel.Value == src )
					_backpack.ClearSelection();
				else
					_backpack.Select( src.row, src.col );
			}
		}

		if ( Input.Pressed( "Attack2" ) && _hoveredSlot.HasValue )
		{
			var (row, col) = _hoveredSlot.Value;
			var item = _backpack.Slots[row, col];
			if ( item.IsValid() ) item.OnUse( _player );
		}
	}

	/// <summary>
	/// `@ref` doesn't reliably bind on plain &lt;div&gt; elements in s&amp;box's razor
	/// parser, so we resolve the hovered slot by walking the grid panel's children
	/// each frame and hit-testing each cell against `Mouse.Position`. Cell index
	/// ordering matches the razor render loop: rows top-to-bottom, cells left-to-
	/// right within a row.
	/// </summary>
	private void PollHoveredSlot()
	{
		if ( !_isOpen || !_backpack.IsValid() || Panel is null )
		{
			_hoveredSlot = null;
			return;
		}

		_gridPanel ??= FindByClass( Panel, "grid" );
		if ( _gridPanel is null )
		{
			_hoveredSlot = null;
			return;
		}

		var screenPos = Mouse.Position;
		int r = 0;
		foreach ( var rowPanel in _gridPanel.Children )
		{
			int c = 0;
			foreach ( var cellPanel in rowPanel.Children )
			{
				if ( cellPanel.IsInside( screenPos ) )
				{
					_hoveredSlot = (r, c);
					return;
				}
				c++;
			}
			r++;
		}

		_hoveredSlot = null;
	}

	/// <summary>
	/// Same polling pattern as cells: walk the sort-buttons panel's children and
	/// match cursor position against each button's screen-space bounds. Order in the
	/// razor template is New / Worth / Weight.
	/// </summary>
	private void PollHoveredSortButton()
	{
		if ( !_isOpen || Panel is null )
		{
			_hoveredSortButton = null;
			return;
		}

		_sortButtonsPanel ??= FindByClass( Panel, "sort-buttons" );
		if ( _sortButtonsPanel is null )
		{
			_hoveredSortButton = null;
			return;
		}

		var screenPos = _mousePos;
		int i = 0;
		foreach ( var child in _sortButtonsPanel.Children )
		{
			if ( child.IsInside( screenPos ) )
			{
				_hoveredSortButton = i switch
				{
					0 => Backpack.SortMode.New,
					1 => Backpack.SortMode.Worth,
					2 => Backpack.SortMode.Weight,
					_ => (Backpack.SortMode?)null,
				};
				return;
			}
			i++;
		}

		_hoveredSortButton = null;
	}

	private static Sandbox.UI.Panel FindByClass( Sandbox.UI.Panel root, string className )
	{
		if ( root is null ) return null;
		if ( root.HasClass( className ) ) return root;
		foreach ( var child in root.Children )
		{
			var found = FindByClass( child, className );
			if ( found is not null ) return found;
		}
		return null;
	}

	private void Toggle()
	{
		if ( _isOpen ) Close();
		else Open();
	}

	private void Open()
	{
		if ( _isOpen ) return;
		_isOpen = true;
		_uiState?.RequestUIFocus( this );
	}

	private void Close()
	{
		if ( !_isOpen ) return;
		_isOpen = false;
		_dragSource = null;
		_dragging = false;
		_hoveredSlot = null;
		_hoveredSortButton = null;
		_gridPanel = null;
		_sortButtonsPanel = null;
		_uiState?.ReleaseUIFocus( this );
		_backpack?.ClearSelection();
	}

	private string CellStyle( BaseItem item, bool selected )
	{
		// s&box CSS doesn't support `inset` shadows OR CSS custom properties, so
		// rarity = a colored border, selection = an outer green box-shadow. Both
		// stack visually without conflicting in the same `box-shadow` declaration.
		//
		// IMPORTANT: always emit explicit `border:` and `box-shadow:` declarations.
		// Returning "" or omitting a property when transitioning a cell from filled
		// → empty leaves the previous inline declarations visually applied (s&box's
		// CSS parser doesn't reset cleared inline properties to class defaults). The
		// fallback "none" forces a clean reset.
		//
		// Note: the drag-source cell is rendered with `item == null` from the razor
		// loop, so it falls through to the `border: none` branch below — no special
		// `_dragging` early-return needed (and adding one would also wipe the borders
		// of every *other* slot mid-drag, which the user explicitly does NOT want).

		var sb = new System.Text.StringBuilder();

		var rarityCfg = item.IsValid() ? _player?.Components.Get<RarityConfig>() : null;
		if ( rarityCfg is not null )
		{
			var c = rarityCfg.GetColor( item.Rarity );
			sb.Append( $"border: 2px solid rgba({(int)(c.r * 255)},{(int)(c.g * 255)},{(int)(c.b * 255)},0.85);" );
		}
		else
		{
			sb.Append( "border: none;" );
		}

		sb.Append( selected
			? "box-shadow: 0 0 12px 2px rgba(111,220,124,0.85);"
			: "box-shadow: none;" );

		return sb.ToString();
	}

	private string FallbackLabel( BaseItem item )
	{
		if ( !item.IsValid() ) return "";
		var name = string.IsNullOrEmpty( item.DisplayName ) ? item.GameObject.Name : item.DisplayName;
		if ( string.IsNullOrEmpty( name ) ) return "?";
		return name.Substring( 0, System.Math.Min( 3, name.Length ) ).ToUpperInvariant();
	}

	private string FormatStack( BaseItem item )
	{
		if ( item is MoneyPickup ) return $"${item.StackCount:N0}";
		return $"x{item.StackCount}";
	}

	/// <summary>
	/// Drag-ghost background. With a baked icon we render `background-image: url(...)`;
	/// otherwise the ghost is empty and the fallback label inside it provides the
	/// visual. Empty `url()` crashes the render tree, so guard the path.
	/// </summary>
	private string GhostBackground( BaseItem item )
	{
		return string.IsNullOrEmpty( item.Icon )
			? ""
			: $"background-image: url({item.Icon});";
	}

	private string TooltipName( BaseItem item )
	{
		if ( !string.IsNullOrEmpty( item.DisplayName ) ) return item.DisplayName;
		return item.GameObject?.Name ?? "Item";
	}

	private System.Collections.Generic.IEnumerable<(string Label, string Value)> TooltipRows( BaseItem item )
	{
		var rows = new System.Collections.Generic.List<(string, string)>();

		if ( item is MoneyPickup money )
		{
			rows.Add( ("Total", $"${money.StackCount:N0}") );
			return rows;
		}

		rows.Add( ("Value", $"${item.Value * item.StackCount:N0}") );
		rows.Add( ("Weight", $"{item.Weight * item.StackCount}") );

		if ( item.StackCount > 1 )
		{
			rows.Add( ("Stack", $"{item.StackCount} / {item.MaxStack}") );
		}

		if ( item is WeaponPickup weapon )
		{
			rows.Add( ("—", "") );
			rows.Add( ("Damage", $"{weapon.Damage:0}") );
			rows.Add( ("Range", $"{weapon.Range:0}") );
			rows.Add( ("Magazine", $"{weapon.MagazineSize}") );
			rows.Add( ("Reload", $"{weapon.ReloadDuration:0.0}s") );
			rows.Add( ("Hold Type", $"{weapon.HoldType}") );
		}

		return rows;
	}

	protected override int BuildHash()
	{
		if ( _backpack is null ) return _isOpen ? 1 : 0;
		var sel = _backpack.Selected;
		var slotHash = 0;
		for ( int r = 0; r < _backpack.Rows; r++ )
		{
			for ( int c = 0; c < _backpack.Cols; c++ )
			{
				var item = _backpack.Slots[r, c];
				slotHash = System.HashCode.Combine( slotHash, item?.GetHashCode() ?? 0, item?.StackCount ?? 0 );
			}
		}
		// Drag ghost follows the cursor, so its position needs to invalidate the
		// hash every mouse-move while dragging. Tooltip is now grid-anchored, so
		// hover doesn't need the same per-pixel rebuild.
		var pmp = CursorCss;
		var movingMouseHash = _dragging ? ((int)pmp.x, (int)pmp.y) : (0, 0);
		return System.HashCode.Combine(
			_isOpen, _dragging, _dragSource, sel, slotHash, _hoveredSlot, _hoveredSortButton, movingMouseHash );
	}
}
