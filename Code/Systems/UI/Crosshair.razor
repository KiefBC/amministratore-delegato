@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits PanelComponent

<root>
	<div class="dot"></div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		position: absolute;
		pointer-events: none;
	}

	.dot {
		width: 6px;
		height: 6px;
		background-color: white;
		border-radius: 50%;
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate( -50%, -50% );
		box-shadow: 0px 0px 2px 1px rgba( 0, 0, 0, 0.7 );
	}
</style>