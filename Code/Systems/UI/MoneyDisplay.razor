@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox.Systems.UI
@inherits PanelComponent

<root>
	@if ( UiModeSystem.Current?.HidesHud != true )
	{
		<div class="money @FlashClass">
			<div class="balance-line">
				<span class="label">Cash</span>
				<span class="amount">$@CashAmount.ToString( "N0" )</span>
			</div>
			<div class="balance-line bank">
				<span class="label">Bank</span>
				<span class="amount">$@BankAmount.ToString( "N0" )</span>
			</div>
			@if ( _flashTimer > 0f && _lastDelta != 0 )
			{
				<span class="delta @(_lastDelta > 0 ? "positive" : "negative")">
					@_lastDeltaLabel @(_lastDelta > 0 ? "+" : "")@_lastDelta.ToString( "N0" )
				</span>
			}
		</div>
	}
</root>

@code {
	private const float FlashDuration = 1.8f;

	private int _displayCash;
	private int _displayBank;
	private float _flashTimer;
	private int _lastDelta;
	private string _lastDeltaLabel = "";
	private Backpack _backpack;
	private PlayerFinanceComponent _finance;

	private int CashAmount => _displayCash;
	private int BankAmount => _displayBank;
	private string FlashClass => _flashTimer > 0f
		? (_lastDelta > 0 ? "flash-positive" : "flash-negative")
		: "";

	protected override void OnStart()
	{
		FindLocalState();
		_displayCash = _backpack?.Wallet ?? 0;
		_displayBank = _finance?.BankBalance ?? 0;
	}

	protected override void OnUpdate()
	{
		FindLocalState();

		var cash = _backpack?.Wallet ?? 0;
		var bank = _finance?.BankBalance ?? 0;
		if ( bank != _displayBank )
		{
			_lastDelta = bank - _displayBank;
			_lastDeltaLabel = "Bank";
			_displayBank = bank;
			_flashTimer = FlashDuration;
		}
		else if ( cash != _displayCash )
		{
			_lastDelta = cash - _displayCash;
			_lastDeltaLabel = "Cash";
			_displayCash = cash;
			_flashTimer = FlashDuration;
		}

		if ( _flashTimer > 0f )
		{
			_flashTimer -= Time.Delta;
		}
	}

	private void FindLocalState()
	{
		_backpack = Sandbox.Systems.Movement.LocalPlayer.Component<Backpack>( Scene );
		_finance = Sandbox.Systems.Movement.LocalPlayer.Component<PlayerFinanceComponent>( Scene );
	}

	protected override int BuildHash() => System.HashCode.Combine( _displayCash, _displayBank, _flashTimer > 0f, System.Math.Sign( _lastDelta ), _lastDeltaLabel, UiModeSystem.Current?.HidesHud == true );
}
