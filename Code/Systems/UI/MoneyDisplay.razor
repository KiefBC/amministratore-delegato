@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits PanelComponent
@implements IMoneyChangedListener

<root>
	<div class="money @FlashClass">
		<span class="amount">$@Amount.ToString( "N0" )</span>
		@if ( _flashTimer > 0f && _lastDelta != 0 )
		{
			<span class="delta @(_lastDelta > 0 ? "positive" : "negative")">
				@(_lastDelta > 0 ? "+" : "")@_lastDelta.ToString( "N0" )
			</span>
		}
	</div>
</root>

@code {
	private const float FlashDuration = 0.6f;

	private int _displayAmount;
	private float _flashTimer;
	private int _lastDelta;

	private int Amount => _displayAmount;
	private string FlashClass => _flashTimer > 0f
		? (_lastDelta > 0 ? "flash-positive" : "flash-negative")
		: "";

	public void OnMoneyChanged( int newAmount, int delta )
	{
		_displayAmount = newAmount;
		_lastDelta = delta;
		_flashTimer = FlashDuration;
	}

	protected override void OnStart()
	{
		_displayAmount = EconomySystem.Current?.Money ?? 0;
	}

	protected override void OnUpdate()
	{
		if ( _flashTimer > 0f )
		{
			_flashTimer -= Time.Delta;
		}
	}

	protected override int BuildHash() => System.HashCode.Combine( _displayAmount, _flashTimer > 0f, System.Math.Sign( _lastDelta ) );
}

<style>
	root {
		width: 100%;
		height: 100%;
		position: absolute;
		pointer-events: none;
	}

	.money {
		position: absolute;
		top: 24px;
		right: 32px;
		flex-direction: row;
		align-items: center;
		gap: 12px;
		padding: 10px 22px;
		background-color: rgba( 0, 0, 0, 0.55 );
		border-radius: 8px;
		font-family: Roboto, sans-serif;
		transition: all 0.15s ease-out;
	}

	.money.flash-positive {
		background-color: rgba( 30, 120, 40, 0.75 );
		box-shadow: 0px 0px 12px 2px rgba( 80, 220, 100, 0.6 );
	}

	.money.flash-negative {
		background-color: rgba( 140, 30, 30, 0.75 );
		box-shadow: 0px 0px 12px 2px rgba( 220, 80, 80, 0.6 );
	}

	.amount {
		color: white;
		font-size: 28px;
		font-weight: bold;
		text-shadow: 0px 0px 4px rgba( 0, 0, 0, 0.9 );
	}

	.delta {
		font-size: 18px;
		font-weight: bold;
		text-shadow: 0px 0px 4px rgba( 0, 0, 0, 0.9 );
	}

	.delta.positive { color: #6fdc7c; }
	.delta.negative { color: #ff7b7b; }
</style>
