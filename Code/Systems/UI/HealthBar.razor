@using Sandbox;
@using Sandbox.UI;
@using System.Linq;
@namespace Sandbox
@inherits PanelComponent
@implements IDamagedListener

<root>
	@if ( Player is not null )
	{
		<div class="health @FlashClass">
			<div class="bar-bg">
				<div class="bar-fill @FillClass" style="width: @(Pct * 100)%;"></div>
			</div>
			<div class="numbers">@_displayHealth.ToString( "F0" ) / @_maxHealth.ToString( "F0" )</div>
		</div>
	}
</root>

@code {
	/// <summary>
	/// The player's UnitComponent. Auto-found in OnStart by Team == Player if not wired.
	/// </summary>
	[Property] public UnitComponent Player { get; set; }

	private const float FlashDuration = 0.25f;

	private float _displayHealth;
	private float _maxHealth = 100f;
	private float _flashTimer;

	private float Pct => _maxHealth > 0f ? float.Clamp( _displayHealth / _maxHealth, 0f, 1f ) : 0f;
	private string FlashClass => _flashTimer > 0f ? "flash-hit" : "";

	private string FillClass => Pct switch
	{
		> 0.6f => "fill-good",
		> 0.3f => "fill-warn",
		_ => "fill-danger"
	};

	public void OnDamaged( Component.IDamageable target, DamageInfo info )
	{
		if ( Player is null ) return;
		if ( target is not UnitComponent unit || unit != Player ) return;

		_displayHealth = Player.Health;
		if ( info.Damage > 0f ) _flashTimer = FlashDuration;
	}

	protected override void OnStart()
	{
		Player ??= Scene.GetAllComponents<UnitComponent>()
			.FirstOrDefault( u => u.Team == TeamType.Player );

		if ( Player is not null )
		{
			_displayHealth = Player.Health;
			_maxHealth = Player.MaxHealth;
		}
	}

	protected override void OnUpdate()
	{
		if ( _flashTimer > 0f )
		{
			_flashTimer -= Time.Delta;
		}

		// Catch any health change that didn't come through OnDamaged (e.g. respawn, debug button).
		if ( Player is not null && Player.Health != _displayHealth )
		{
			_displayHealth = Player.Health;
		}
	}

	protected override int BuildHash() => System.HashCode.Combine( _displayHealth, _maxHealth, _flashTimer > 0f );
}
