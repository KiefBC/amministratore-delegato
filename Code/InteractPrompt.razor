@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
	@if ( Target is not null )
	{
		<div class="prompt">Press <span class="key">E</span> to @Verb</div>
	}
</root>

@code {
	private IInteractable Target => InteractionSystem.Current?.CurrentTarget;
	private string Verb => ExtractVerb( Target?.Prompt );

	/// <summary>
	/// IInteractable.Prompt convention is "Press E to {verb}". Strip the prefix so we can
	/// render the E with key styling without HTML-injection in the prompt string itself.
	/// </summary>
	private static string ExtractVerb( string prompt )
	{
		if ( string.IsNullOrEmpty( prompt ) ) return "";
		var idx = prompt.LastIndexOf( " to " );
		return idx < 0 ? prompt : prompt[(idx + 4)..];
	}

	protected override int BuildHash() => System.HashCode.Combine( Target?.Prompt );
}

<style>
	root {
		width: 100%;
		height: 100%;
		position: absolute;
		pointer-events: none;
	}

	.prompt {
		position: absolute;
		left: 50%;
		bottom: 25%;
		transform: translateX( -50% );
		color: white;
		font-size: 24px;
		text-shadow: 0px 0px 4px rgba( 0, 0, 0, 0.9 );
		background-color: rgba( 0, 0, 0, 0.5 );
		padding: 8px 20px;
		border-radius: 6px;
		font-family: Roboto, sans-serif;
	}

	.key {
		color: yellow;
		font-weight: bold;
	}
</style>
